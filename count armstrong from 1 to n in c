#include <stdio.h>
int main(){
    int n,count=0;
    scanf("%d",&n);

    for(int i=1;i<=n;i++){
        int a=i;
        int s=i;
        int dig=0,sum=0;
        while(a>0){
        a/=10;
        dig++;
    }
    while(s>0){
        int d=s%10;
        int pow=1;
        for(int i=0;i<dig;i++){
            pow*=d;
        }
        sum+=pow;
        s/=10;
    }
    if(sum==i){
        count++;
    }
}
    printf("%d ",count);
    return 0;
}
