#include <stdio.h>
    int LomutoPart(int a[],int l,int r){
        int i=l-1;
        for(int j=l;j<r;j++){
            if(a[j]<=a[r]){
                i++;
                int temp=a[i];
                a[i]=a[j];
                a[j]=temp;
            }
        }
        int temp=a[i+1];
        a[i+1]=a[r];
        a[r]=temp;
        return i+1;
    }

    void qSort(int a[],int l,int r){
    if(l<r){
        int p=LomutoPart(a,l,r);
        qSort(a,l,p-1);
        qSort(a,p+1,r);
    }
}    

int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }

    qSort(a,0,n-1);

    for(int i=0;i<n;i++){
        printf("%d ",a[i]);
    }

    return 0;
}
