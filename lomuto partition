#include <stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    int l=0,i=l-1,h=n-1;
    int p=a[h];
    for(int j=l;j<h;j++){
        if(a[j]<=p){
            i++;
            int temp=a[i];
            a[i]=a[j];
            a[j]=temp;
        }
    }
    int temp=a[i+1];
    a[i+1]=a[h];
    a[h]=temp;

    for(int k=0;k<n;k++){
        printf("%d ",a[k]);
    }
}
