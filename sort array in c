#include <stdio.h>
int main(){
    int x;
    scanf("%d",&x);
    int a[x];
    
    for(int i=0;i<x;i++){
            scanf("%d",&a[i]);
    }


    for(int i=0;i<x-1;i++){
        for(int j=0;j<x-1-i;j++){
            int temp=a[j];
            a[j]=a[j+1];
            a[j+1]=temp;
        }
    }


    for(int i=0;i<x;i++){
        printf("%d",a[i]);
    }

}
