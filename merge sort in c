#include <stdio.h>
    void merge(int a[],int l,int mid,int r){
        int i=l,j=mid+1,k=0;
        int temp[r-l+1];
        while(i<=mid&&j<=r){
            if(a[i]>=a[j])
            temp[k++]=a[j++];
        
        else
            temp[k++]=a[i++];
        }
        while(i<=mid)
            temp[k++]=a[i++];
        
        while(j<=r)
            temp[k++]=a[j++];
        
        for(int i=l,k=0;i<=r;i++,k++)
            a[i]=temp[k];
        
    }

    void mergeSort(int a[],int l,int r){
    if(l<r){
        int mid=(l+r)/2;
        mergeSort(a,l,mid);
        mergeSort(a,mid+1,r);
        merge(a,l,mid,r);
    }
}    

int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    
    for(int i=0;i<n;i++)
        scanf("%d",&a[i]);

    mergeSort(a,0,n-1);

    for(int i=0;i<n;i++)
        printf("%d ",a[i]);

    return 0;
}
