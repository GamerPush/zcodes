#include<stdio.h>
int main(){
int x;
scanf("%d",&x);
int a[x][x],b[x][x],c[x][x];
for(int i=0;i<x;i++){
    for(int j=0;j<x;j++){
    scanf("%d",&a[i][j]);
}
}

for(int i=0;i<x;i++){
    for(int j=0;j<x;j++){
    scanf("%d",&b[i][j]);
}
}

for(int i=0;i<x;i++){
    for(int j=0;j<x;j++){
        c[i][j]=0;
        for(int k=0;k<x;k++){
        c[i][j]+=a[i][k]*b[k][j];
        }
    printf("%d ",c[i][j]);
}
printf("\n");
}
return 0;
}
