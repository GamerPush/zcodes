#include <stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    int l=0,h=n-2,p=n-1;
    int temp[h-l+1],ind=0;
    for(int i=l;i<=h;i++){
        if(a[i]<=a[p]&&i!=p){
            temp[ind]=a[i];
            ind++;
            temp[ind]=a[p];
        }
    }

    for(int i=l;i<=h;i++){
        if(a[i]>a[p]){
            temp[ind]=a[i];
            ind++;
        }
    }

    for(int i=l;i<=h;i++){
        a[i]=temp[i-l];
        printf("%d ",a[i]);
    }
}
