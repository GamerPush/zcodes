#include <stdio.h>

int main(){
    int n, m;
    scanf("%d %d", &n, &m);

    int a[n][m];

    for(int i = 0; i < n; i++){
        for(int j = 0; j < m; j++){
            scanf("%d", &a[i][j]);
        }
    }

    // top row
    for(int j = 0; j < m; j++){
        printf("%d ", a[0][j]);
    }

    // right column
    for(int i = 1; i < n; i++){
        printf("%d ", a[i][m-1]);
    }

    // bottom row (reverse)
    if(n > 1){
        for(int j = m-2; j >= 0; j--){
            printf("%d ", a[n-1][j]);
        }
    }

    // left column (reverse)
    if(m > 1){
        for(int i = n-2; i > 0; i--){
            printf("%d ", a[i][0]);
        }
    }

    return 0;
}
