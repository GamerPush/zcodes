#include <stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    int l=0,i=l-1,h=n-1,j=h+1;
    int p=a[l];
    while(1){
        do{
            i++;
        }while(a[i]<p);

        do{
            j--;
        }while(a[j]>p);
        
        if(i>=j){
            break;
        }
        int temp=a[i];
        a[i]=a[j];
        a[j]=temp;
    }

    for(int k=0;k<n;k++){
        printf("%d ",a[k]);
    }
}
