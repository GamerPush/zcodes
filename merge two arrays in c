#include <stdio.h>
int main(){
    int n,m;
    int i=0,j=0,k=0;
    scanf("%d %d",&n,&m);
    int a[n],b[m];
    int*c=(int*)malloc((n+m)*sizeof(int));

    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }

    for(int j=0;j<m;j++){
        scanf("%d",&b[j]);
    }

    while(i<n&&j<m){
        
        if(a[i]>b[j]){
            c[k]=b[j];
            k++;
            j++;
        }

        else{
            c[k]=a[i];
            k++;
            i++;
        }
    }

    while(i<n){
        c[k]=a[i];
        i++;
        k++;
    }

    
    while(j<m){
        c[k]=b[j];
        j++;
        k++;
    }
    for(int i=0;i<n+m;i++){
        printf("%d",c[i]);
    }
    }
