#include <stdio.h>
int main(){
    int size,target;
    scanf("%d %d",&size,&target);
    int a[size];

    for(int i=0;i<size;i++){
        scanf("%d",&a[i]);
    }
    
    for(int i=0;i<size;i++){
        for(int j=0;j<i;j++){
            if(a[i]+a[j]==target){
                printf("Lucky Pair:(%d,%d)\n",a[i],a[j]);
            }
        }
    }
    return 0;
}
