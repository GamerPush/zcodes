import java.util.Scanner;
public class Practice1 {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        int n = input.nextInt();
        int a=1;
        int b=1;
        for(int i=1;i<=n;i++){
            if(i%2!=0){
                System.out.println(a*3);
                a++;
            }
            else{
                System.out.println(b*5);
                b++;
            }
        }
    }
}
